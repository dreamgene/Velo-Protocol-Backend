{
  "name": "@velo-protocol/pay",
  "version": "0.1.0",
  "description": "Velo USDC payment SDK for Stellar",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist", "public"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  },
  "peerDependencies": {},
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dreamgene/Velo-Protocol-Backend",
    "directory": "velo-sdk"
  }
}
